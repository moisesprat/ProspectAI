# ProspectAI Environment Configuration
# Copy this file to .env and fill in your actual values:
#   cp env.example .env
#
# Required keys are marked [REQUIRED].
# Optional keys are marked [OPTIONAL] and can be left commented out.

# ── LLM selection (simple mode) ────────────────────────────────────────────────
# MODEL_PROVIDER: anthropic | ollama
MODEL_PROVIDER=anthropic
# MODEL: global default model id for all agents (raw id, no provider prefix)
MODEL=claude-haiku-4-5-20251001

# Anthropic API key required when MODEL_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional per-agent overrides (override MODEL for that agent only)
# AGENT_MARKET_ANALYST_MODEL=claude-sonnet-4-6
# AGENT_TECHNICAL_ANALYST_MODEL=
# AGENT_FUNDAMENTAL_ANALYST_MODEL=
# AGENT_INVESTOR_STRATEGIC_MODEL=

# ── Market data — at least one of the two blocks below is [REQUIRED] ──────────

# Option A: Reddit API (preferred — richer sentiment data)
# Get credentials at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=ProspectAI/1.0          # [OPTIONAL] default shown

# Option B: Serper web search fallback (used when Reddit credentials are absent)
# Get your key at https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# ── Ollama [OPTIONAL] — needed when MODEL_PROVIDER=ollama ──────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Legacy fallback only (prefer MODEL):
# OLLAMA_MODEL=qwen3.5:9b

# Legacy Anthropic fallback only (prefer MODEL):
# ANTHROPIC_MODEL=claude-sonnet-4-6
